{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "seseri-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-09-06",
  "observability": { "enabled": true },
  // KV: rate-limit counters + health-checked YT instance list
  "kv_namespaces": [
    { "binding": "KV", "id": "REPLACE_ON_DEPLOY" }
  ],
  // Refresh the healthy Piped/Invidious list twice an hour
  "triggers": { "crons": ["*/30 * * * *"] }
}
