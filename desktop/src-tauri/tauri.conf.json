{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Seseri",
  "version": "4.0.0",
  "identifier": "io.github.iacbi.seseri",
  "build": {
    "frontendDist": "https://iacbi.github.io/seseri/",
    "devUrl": "https://iacbi.github.io/seseri/"
  },
  "app": {
    "windows": [
      {
        "title": "Seseri",
        "width": 1180,
        "height": 780,
        "minWidth": 360,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "IACBI",
    "shortDescription": "Free, no-account podcast player",
    "icon": ["icons/icon.ico", "icons/128x128.png", "icons/32x32.png"],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Turkish", "English"]
      }
    }
  }
}
